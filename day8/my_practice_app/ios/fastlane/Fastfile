# ios/fastlane/Fastfile

# Find Flutter SDK - check FVM first, then common locations
def find_flutter
  # Check if FVM is available
  fvm_path = `which fvm`.strip
  if !fvm_path.empty?
    return "fvm flutter"
  end

  # Check for Flutter in PATH
  flutter_path = `which flutter`.strip
  if !flutter_path.empty?
    return flutter_path
  end

  # Check common installation locations
  common_paths = [
    ENV['FLUTTER_HOME'],
    '/usr/local/flutter/bin/flutter',
    '/opt/homebrew/bin/flutter',
    '/Users/$HOME/development/flutter/bin/flutter',
    '/Users/$HOME/fvm/default/bin/flutter'
  ].compact

  common_paths.each do |path|
    if File.exist?(path.gsub('$HOME', ENV['HOME'] || '~'))
      return path.gsub('$HOME', ENV['HOME'] || '~')
    end
  end

  nil
end

# Add Flutter to PATH for all lanes
ENV['PATH'] = "/usr/local/bin:/opt/homebrew/bin:/usr/local/flutter/bin:#{ENV['PATH']}"

default_platform(:ios)

platform :ios do

  # ─── Test Lane ───────────────────────────────────────
  desc "Run Flutter tests"
  lane :test do
    flutter_cmd = find_flutter
    if flutter_cmd.nil?
      puts "⚠️  Flutter not found. Please install Flutter or FVM"
      puts "   FVM: https://fvm.app"
      raise "Flutter not found"
    end

    puts "🔍 Using Flutter: #{flutter_cmd}"

    Dir.chdir("../../") do
      sh("#{flutter_cmd} test")
    end
  end

  # ─── Build iOS (no signing) ──────────────────────────
  desc "Build iOS without code signing (practice)"
  lane :build do
    flutter_cmd = find_flutter
    if flutter_cmd.nil?
      puts "⚠️  Flutter not found. Please install Flutter or FVM"
      puts "   FVM: https://fvm.app"
      raise "Flutter not found"
    end

    puts "🔍 Using Flutter: #{flutter_cmd}"

    Dir.chdir("../../") do
      begin
        sh("#{flutter_cmd} build ios --release --no-codesign")
      rescue => e
        puts "⚠️  iOS build failed: #{e.message}"
        puts "   iOS platform may not be configured for this Flutter project"
        puts "   Run: flutter create . --platforms=ios"
        puts "   Skipping iOS build for practice setup"
        return
      end
    end
    puts "✅ iOS build complete (no code signing)"
  end

  # ─── Full CI Pipeline ────────────────────────────────
  desc "Run tests + build"
  lane :ci do
    test
    build
  end

  # ─── (Simulated) Deploy Lane ─────────────────────────
  desc "Simulate deploy to App Store"
  lane :deploy do
    build
    puts "🚀 [SIMULATED] Would upload to TestFlight/App Store here"
    puts "    In real setup, use: upload_to_app_store() or pilot()"
  end

  # ─── Environment-Specific Builds ─────────────────────
  desc "Build dev environment iOS"
  lane :build_dev do
    flutter_cmd = find_flutter
    raise "Flutter not found" if flutter_cmd.nil?

    puts "🔍 Building DEV environment"

    Dir.chdir("../../") do
      begin
        sh("#{flutter_cmd} build ios --release --no-codesign --dart-define=ENV=dev --dart-define=API_URL=https://dev-api.example.com")
      rescue => e
        puts "⚠️  iOS build failed: #{e.message}"
        puts "   iOS platform may not be configured for this Flutter project"
        return
      end
    end
    puts "✅ Dev iOS built!"
  end

  desc "Build staging environment iOS"
  lane :build_staging do
    flutter_cmd = find_flutter
    raise "Flutter not found" if flutter_cmd.nil?

    puts "🔍 Building STAGING environment"

    Dir.chdir("../../") do
      begin
        sh("#{flutter_cmd} build ios --release --no-codesign --dart-define=ENV=staging --dart-define=API_URL=https://staging-api.example.com")
      rescue => e
        puts "⚠️  iOS build failed: #{e.message}"
        puts "   iOS platform may not be configured for this Flutter project"
        return
      end
    end
    puts "✅ Staging iOS built!"
  end

  desc "Build production environment iOS"
  lane :build_prod do
    flutter_cmd = find_flutter
    raise "Flutter not found" if flutter_cmd.nil?

    puts "🔍 Building PRODUCTION environment"

    Dir.chdir("../../") do
      begin
        sh("#{flutter_cmd} build ios --release --no-codesign --dart-define=ENV=prod --dart-define=API_URL=https://api.example.com")
      rescue => e
        puts "⚠️  iOS build failed: #{e.message}"
        puts "   iOS platform may not be configured for this Flutter project"
        return
      end
    end
    puts "✅ Production iOS built!"
  end

  # ─── Environment Deploy Lanes ────────────────────────
  desc "Deploy dev to TestFlight"
  lane :deploy_dev do
    build_dev
    puts "🚀 [SIMULATED] Would upload DEV to TestFlight"
  end

  desc "Deploy staging to TestFlight"
  lane :deploy_staging do
    build_staging
    puts "🚀 [SIMULATED] Would upload STAGING to TestFlight"
  end

  desc "Deploy production to App Store"
  lane :deploy_prod do
    build_prod
    puts "🚀 [SIMULATED] Would upload PRODUCTION to App Store"
  end

end